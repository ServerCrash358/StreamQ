# Copy to .env for host-side runs (workers/API on the host). Not used by
# docker compose, which injects config via the service `environment:` blocks.
APP_ENV=development
REDIS_URL=redis://localhost:6381/0
DATABASE_URL=postgresql://streamq:streamq@localhost:5436/streamq
MAX_RETRIES=3
WORKER_CONCURRENCY=4
RATE_LIMIT_PER_WINDOW=100
RATE_LIMIT_WINDOW_SECONDS=60
